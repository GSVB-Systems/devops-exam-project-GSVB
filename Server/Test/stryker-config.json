{
  "stryker-config": {
    "project": "DevOpsAppApi.csproj",
    "reporters": [
      "html",
      "json",
      "progress"
    ],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "mutate": [
      "../Service/Services/**/*.cs",
      "../Service/Auth/**/*.cs",
      "../Service/EggApi/**/*.cs",
      "../Repository/Repos/**/*.cs",
      "!**/*Dto.cs",
      "!**/*Options.cs",
      "!**/Migrations/*.cs",
      "!**/Program.cs",
      "!**/GenerateTypeScript.cs",
      "!**/Class1.cs"
    ]
  }
}
